profile memcr /usr/bin/memcr flags=(attach_disconnected) {
    /etc/ssl/openssl.cnf r,
    /lib/libpthread*.so* mr,
    /lib/libc*.so* mr,
    /usr/lib/liblz4*.so* mr,
    /usr/lib/libzstd.so* mr,
    /proc/*/status r,
    /usr/lib/libcrypto*.so* mr,
    /lib/libsystemd*.so* mr,
    /lib/libdl*.so* mr,
    /lib/librt*.so* mr,
    /lib/libm*.so* mr,
    /lib/libresolv*.so* mr,
    /usr/lib/memcr/libencrypt*.so* mr,
    /usr/bin/memcr mrix,
}
