profile audioserver /usr/bin/audioserver flags=(attach_disconnected) {
    /dev/urandom rw,
    /dev/zero r,
    /lib/ld*.so* mr,
    /lib/libc*.so* mr,
    /lib/libdl*.so* mr,
    /lib/libgcc_s*.so* mr,
    /lib/libm*.so* mr,
    /lib/libpthread*.so* mr,
    /lib/librt*.so* mr,
    /proc/*/status r,
    /proc/cpuinfo r,
    /sys/devices/system/cpu/possible r,
    /sys/devices/system/cpu/present r,
    /usr/lib/libasan*.so* mr,
    /usr/lib/libasound*.so* mr,
    /usr/lib/libbreakpadwrapper*.so* mr,
    /usr/lib/libstdc++*.so* mr,
    /usr/lib/libzstd.so* mr,
}
