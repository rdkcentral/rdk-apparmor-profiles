    /lib/libnss_files*.so* mr,
    /lib/libresolv*.so* mr,
    /lib/librt*.so* mr,
    /lib/libsystemd*.so* mr,
    /lib/libtinfo*.so* mr,
    /lib/libz*.so* mr,
    /lib/libnss_mdns*_minimal*.so* mr,
    /usr/lib/libnss_mdns*.so* mr,
    /usr/lib/libRdkCertSelector*.so* mr,
    /proc/*/auxv r,
    /proc/*/cmdline r,
    /proc/*/comm r,
    /proc/cpuinfo r,
    /proc/*/environ r,
    /proc/*/fd/* rw,
    /proc/loadavg r,
    /proc/meminfo r,
    /proc/ r,
    /proc/*/statm r,
    /proc/*/stat r,
    /proc/stat r,
    /proc/*/status r,
    /proc/sys/kernel/ngroups_max r,
    /proc/sys/kernel/osrelease r,
    /proc/sys/kernel/pid_max r,
    /proc/sys/vm/overcommit_memory r,
    /proc/sys/vm/min_free_kbytes r,
    /proc/*/task/ r,
    /proc/uptime r,
    /proc/*/ r,
    /proc/*/task/*/comm rw,
    /sys/devices/system/cpu/online r,
    /sys/devices/system/cpu/possible r,
    /sys/devices/system/cpu/present r,
    /usr/bin/gawk mrix,
    /usr/bin/telemetry2_0 mrix,
    /usr/bin/top.procps mrix,
    /usr/lib/libbreakpadwrapper*.so* mr,
    /usr/lib/libbulkdata*.so* mr,
    /usr/lib/libccspinterface*.so* mr,
    /usr/lib/libcimplog*.so* mr,
    /usr/lib/libcjson*.so* mr,
    /usr/lib/libcrypt*.so* mr,
    /usr/lib/libcurl*.so* mr,
    /usr/lib/libdcautil*.so* mr,
    /usr/lib/libglib*.so* mr,
    /usr/lib/libhttp*.so* mr,
    /usr/lib/libidn*.so* mr,
    /usr/lib/libjsoncpp*.so* mr,
    /usr/lib/liblog*c*.so* mr,
    /usr/lib/libmsgpackc*.so* mr,
    /usr/lib/libnss_myhostname*.so* mr,
    /usr/lib/liboauth*.so* mr,
    /usr/lib/libpcre*.so* mr,
    /usr/lib/libprivilege*.so* mr,
    /usr/lib/libprocps*.so* mr,
    /usr/lib/librbuscore*.so* mr,
