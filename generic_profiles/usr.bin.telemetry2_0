profile telemetry2_0 /usr/bin/telemetry2_0 flags=(attach_disconnected) {
    /bin/bash.bash mrix,
    /bin/busybox.nosuid mrix,
    /bin/pidof.procps mrix,
    /dev/null rw,
    /dev/tty rw,
    /etc/debug.ini r,
    /etc/device.properties r,
    /etc/host.conf r,
    /etc/hosts r,
    /etc/include.properties r,
    /etc/ld.so.conf r,
    /etc/log*crc r,
    /etc/nsswitch.conf r,
    /etc/nss_mdns.conf r,
    /etc/security/caps/process-capabilities.json r,
    /etc/ssl/openssl.cnf r,
    /etc/terminfo/d/dumb r,
    /lib/ld*.so* mr,
    /lib/libcap*.so* mr,
    /lib/libc*.so* mr,
    /lib/libdl*.so* mr,
    /lib/libgcc_s*.so* mr,
    /lib/libm*.so* mr,
    /lib/libpthread*.so* mr,
    /lib/libnss_compat*.so* mr,
