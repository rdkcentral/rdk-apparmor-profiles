profile telemetry2_0 /usr/bin/telemetry2_0 flags=(attach_disconnected) {
    ptrace,
    signal,
    /proc/*/auxv r,
    /proc/*/cmdline r,
    /proc/*/comm r,
    /proc/cpuinfo r,
    /proc/*/environ r,
    /proc/*/fd/* rw,
    /proc/loadavg r,
    /proc/*/maps r,
    /proc/meminfo r,
    /proc/ r,
    /proc/*/statm r,
    /proc/*/stat r,
    /proc/stat r,
    /proc/*/status r,
    /proc/*/task/ r,
    /proc/uptime r,
    /proc/*/ r,
    /proc/*/task/*/comm rw,
}
