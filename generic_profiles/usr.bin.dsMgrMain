profile dsMgrMain /usr/bin/dsMgrMain flags=(attach_disconnected) {
    /bin/bash.bash mrix,
    /bin/busybox.nosuid mrix,
    /dev/av_metrics rw,
    /dev/mem rw,
    /dev/ion rw,
    /dev/ion_rtk rw,
    /dev/mmcblk* rw,
    /dev/mmcblk1boot0p5 r,
