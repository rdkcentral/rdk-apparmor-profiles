    /dev/dri/ r,
    /dev/zero r,
    /etc/debug.ini r,
    /etc/log4crc r,
    /etc/ld.so.conf r,
    /etc/nsswitch.conf r,
    /etc/ssl/openssl.cnf r,
    /etc/device.properties r,
    /lib/ld*.so* mr,
