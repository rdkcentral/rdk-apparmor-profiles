profile rtrmfplayer /usr/bin/rtrmfplayer flags=(attach_disconnected) {
    /bin/bash.bash mrix,
    /bin/busybox.nosuid mrix,
    /bin/sh mrix,
    /dev/null rw,
    /dev/urandom r,
    /etc/debug.ini r,
    /etc/host.conf r,
    /etc/hosts r,
    /etc/log*crc r,
    /etc/nsswitch.conf r,
    /etc/rtremote.conf r,
    /etc/ssl/openssl.cnf r,
    /etc/udev/udev.conf r,
    /lib/ld*.so* mr,
    /lib/ld-linux-armhf*.so* mr,
    /lib/libblkid*.so* mr,
    /lib/libc*.so* mr,
    /lib/libcap*.so* mr,
